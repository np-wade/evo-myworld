DESC="UCB1 frontier selection strategy (Gemini seat)"
VERIFY_CMD="uv run --no-project --with pytest python -m pytest -q world/gemini/test_ucb.py && uv run --no-project --with pytest python -m pytest -q tests/unit/test_frontier_strategies.py"
SCORE_CMD="python3 -c \"import time, subprocess; t = time.perf_counter(); subprocess.run(['python3', '-c', 'from evo import frontier_strategies as fs; nodes=[{\\'id\\': f\\'exp_{i}\\', \\'score\\': 0.1 * i, \\'eval_epoch\\': 1} for i in range(50)]; fs.pick(nodes, {\\'kind\\': \\'ucb1\\', \\'params\\': {\\'c\\': 1.5, \\'k\\': 5}}, \\'max\\')'], capture_output=True, check=True); print((time.perf_counter() - t) * 1000)\""
METRIC="min — ms for a 50-node UCB1 pick operation"
