DESC="evo-river time-river renderer vs evo tree ASCII renderer"
BASE_CMD="cd /projects/evo-myworld && uv run --project plugins/evo python -c \"import json; from evo.core import ascii_tree; g=json.load(open('world/kimi/fixtures/demo-graph.json')); print(ascii_tree(g, 'min'))\""
NEW_CMD="cd /projects/evo-myworld && uv run --project plugins/evo python world/kimi/evo_river.py --graph world/kimi/fixtures/demo-graph.json --metric min --no-color"
NOTE="river view differs from ascii_tree and renders frontier/spine markers"
