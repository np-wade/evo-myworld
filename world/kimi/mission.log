guments: String, // JSON object\\n}\\n\\npub struct Usage {\\n    pub prompt_tok
ens: u32,\\n    pub completion_tokens: u32,\\n}\\n\\npub enum StreamEvent {\\n  
 Chunk { text: String },\\n    ToolCall { call: ToolCall },\\n    ToolResult { i
