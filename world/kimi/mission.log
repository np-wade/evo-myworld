// ── Color math ───────────────────────────────────────────────────────\n    67
\t//\n    68\t// Only the helpers the truecolor palettes themselves need. There 
is NO\n    69\t// RGB->ANSI conversion at runtime: the reduced-tier palettes bel
ow are\n    70\t// pre-derived literals (see scripts/gen-color-palettes.mjs), so
a level-2\n    71\t// terminal gets curated `ansi256(N)` values instead of chalk
\'s lossy hex\n    72\t// downsample (which collapsed the dark-green border onto
an olive cube cell).\n    73\t\n    74\tfunction parseHex(h: string): [number, n
umber, number] | null {\n    75\t  const m = /^#?([0-9a-f]{6})$/i.exec(h)\n    7
6\t\n    77\t  if (!m) {\n    78\t    return null\n    79\t  }\n    80\t\n    81
\t  const n = parseInt(m[1]!, 16)\n    82\t\n    83\t  return [(n >> 16) & 0xff,
(n >> 8) & 0xff, n & 0xff]\n    84\t}\n    85\t\n    86\tfunction mix(a: string,
b: string, t: number) {\n    87\t  const pa = parseHex(a)\n    88\t  const pb = 
parseHex(b)\n    89\t\n    90\t  if (!pa || !pb) {\n    91\t    return a\n    92
\t  }\n    93\t\n    94\t  const lerp = (i: 0 | 1 | 2) => Math.round(pa[i] + (pb
[i] - pa[i]) * t)\n    95\t\n    96\t  return \'#\' + ((1 << 24) | (lerp(0) << 1
6) | (lerp(1) << 8) | lerp(2)).toString(16).slice(1)\n    97\t}\n    98\t\n    9
