ox-bubblewrap",\n   439\t    "browser-native", "probe",\n   440\t    "plugins-wa
sm", "plugins-wasm-cranelift",\n   441\t    "webauthn", "memory-postgres",\n   4
42\t]\n   443\t\n   444\t[profile.dev]\n   445\tincremental = true\n   446\topt-
level = 0\n   447\t\n   448\t[profile.release]\n   449\topt-level = "z"      # O
