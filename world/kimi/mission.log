 455\t// ── Light/dark detection ─────────────────────────────────────────────\n
  456\t\n   457\tconst TRUE_RE = /^(?:1|true|yes|on)$/\n   458\tconst FALSE_RE =
/^(?:0|false|no|off)$/\n   459\t\n   460\t// TERM_PROGRAM fallback allow-list fo
r terminals whose default profile is\n   461\t// light and which may not expose 
COLORFGBG. Empty by default: a TERM_PROGRAM\n   462\t// alone can\'t tell a ligh
t profile from a dark one (Terminal.app ships both\n   463\t// and emits no COLO
RFGBG either way), and dark profiles are common, so an\n   464\t// undetectable 
terminal stays dark unless an explicit signal (RAVEN_TUI_THEME\n   465\t// / RAV
EN_TUI_LIGHT / RAVEN_TUI_BACKGROUND / COLORFGBG) says light. Still\n   466\t// i
njectable so tests can exercise the precedence rules.\n   467\tconst LIGHT_DEFAU
LT_TERM_PROGRAMS = new Set<string>([])\n   468\t\n   469\t// Best-effort RGB → l
uminance check.  Currently only accepts a 3- or\n   470\t// 6-digit hex value (w
ith or without a leading `#`); the env var name\n   471\t// `RAVEN_TUI_BACKGROUN
D` is intentionally generic so a future OSC11\n   472\t// query helper can cache
its answer there too, but additional formats\n   473\t// (rgb()/hsl()/named colo
urs) would need explicit parsing here first.\n   474\tconst LUMA_LIGHT_THRESHOLD
= 0.6\n   475\t\n   476\t// Strict allow-list: parseInt(..., 16) silently trunca
tes at the first\n   477\t// non-hex character (e.g. `fffgff` would parse as `ff
f` and yield a\n   478\t// false-positive "white" reading), so reject anything t
hat doesn\'t match\n   479\t// the canonical 3- or 6-digit shape up front.\n   4
80\tconst HEX_3_RE = /^[0-9a-f]{3}$/\n   481\tconst HEX_6_RE = /^[0-9a-f]{6}$/\n
  482\t\n   483\tfunction backgroundLuminance(raw: string): null | number {\n   
484\t  const v = raw.trim().toLowerCase()\n   485\t\n   486\t  if (!v) {\n   487
\t    return null\n   488\t  }\n   489\t\n   490\t  const hex = v.startsWith(\'#
\') ? v.slice(1) : v\n   491\t\n   492\t  const rgb = HEX_6_RE.test(hex)\n   493
\t    ? [parseInt(hex.slice(0, 2), 16), parseInt(hex.slice(2, 4), 16), parseInt(
hex.slice(4, 6), 16)]\n   494\t    : HEX_3_RE.test(hex)\n   495\t      ? [parseI
nt(hex[0]! + hex[0]!, 16), parseInt(hex[1]! + hex[1]!, 16), parseInt(hex[2]! + h
ex[2]!, 16)]\n   496\t      : null\n   497\t\n   498\t  if (!rgb) {\n   499\t   
