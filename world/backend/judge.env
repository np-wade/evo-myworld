DESC="evo_graph bridge: FTS search + slice lookup over graphify index.db"
VERIFY_CMD="uv run --no-project --with pytest pytest -q world/backend/test_evo_graph.py && python3 world/backend/evo_graph.py find falkor --limit 3 | grep -qi falkor"
SCORE_CMD="python3 -c \"import time,subprocess;t=time.perf_counter();subprocess.run(['python3','world/backend/evo_graph.py','find','agent memory','--limit','10'],capture_output=True,check=True);print((time.perf_counter()-t)*1000)\""
METRIC="min — ms for a 10-hit FTS query over 5.9M indexed nodes"
